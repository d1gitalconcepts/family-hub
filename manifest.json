{
  "manifest_version": 3,
  "name": "Family Hub - Keep Sync",
  "version": "0.2.0",
  "description": "Scrapes Google Keep and syncs directly to Google Tasks, Calendar, and Supabase",
  "permissions": [
    "scripting",
    "storage",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://keep.google.com/*",
    "https://www.googleapis.com/*",
    "https://tasks.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "scripts": [
      "config.js",
      "storage.js",
      "google-auth.js",
      "google-api.js",
      "supabase-ext.js",
      "tasks-ext.js",
      "calendar-ext.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://keep.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Family Hub Sync"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "family-hub-sync@familyhub.local"
    }
  }
}
