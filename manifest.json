{
  "manifest_version": 3,
  "name": "Family Hub - Keep Sync",
  "version": "0.1.0",
  "description": "Scrapes Google Keep lists and syncs them to Family Hub",
  "permissions": [
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://keep.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://keep.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Family Hub Sync"
  }
}
