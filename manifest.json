{
  "manifest_version": 3,
  "name": "Family Hub - Keep Sync",
  "version": "0.3.0",
  "description": "Scrapes Google Keep and uploads raw notes to Supabase. Calendar and Tasks sync is handled by the Cloudflare Worker.",
  "permissions": [
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://keep.google.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "scripts": [
      "config.js",
      "storage.js",
      "supabase-ext.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://keep.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Family Hub Sync"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "family-hub-sync@familyhub.local"
    }
  }
}
